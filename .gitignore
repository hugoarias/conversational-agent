# ---------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports
report.*.*.*.*.json

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------
# Node / Frontend
# ---------------------------------------------------------
node_modules/
jspm_packages/
bower_components/
web_modules/

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
frontend/dist/

# Vite
frontend/.vite/

# Coverage
coverage/
*.lcov
.nyc_output/

# Caches
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.fusebox/
.grunt/
.docusaurus/
.temp/
.vuepress/dist

# Yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.yarn-integrity
.pnp.*

# TypeScript
*.tsbuildinfo

# Misc Node
.lock-wscript
.node_repl_history
*.tgz
.tern-port

# Serverless
.serverless/
.webpack/

# DynamoDB
.dynamodb/

# ---------------------------------------------------------
# Environment Variables / Secrets
# ---------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env

# ---------------------------------------------------------
# Python
# ---------------------------------------------------------

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# C extensions
*.so

# Packaging
.Python
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
nosetests.xml
*.cover
*.py,cover
cover/
.pytest_cache/
.hypothesis/

# Type checkers / linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# Cython
cython_debug/

# Jupyter
.ipynb_checkpoints

# IPython
profile_default/
ipython_config.py

# Virtual environments
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# PEP 582
__pypackages__/

# Poetry / PDM
poetry.toml
.pdm.toml

# SQLite
db.sqlite3
db.sqlite3-journal

# Frameworks
instance/
.webassets-cache
.scrapy

# Documentation
docs/_build/
/site

# Misc Python
celerybeat-schedule
celerybeat.pid
*.sage.py

# LSP
pyrightconfig.json

