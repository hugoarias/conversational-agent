# ── Server ────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── STT (faster-whisper) ──────────────────────────────────────────────────
# Model sizes: tiny | base | small | medium | large
WHISPER_MODEL_SIZE=base
# Device: cpu | cuda | auto  (use 'cuda' or 'gpu' for NVIDIA GPU; 'gpu' is auto-mapped to 'cuda')
# GPU requires CUDA 12 runtime DLLs. If you see cublas64_12.dll errors, either:
#   a) pip install nvidia-cublas-cu12 nvidia-cudnn-cu12  (uncomment in requirements.txt)
#   b) Install the full CUDA Toolkit 12.x from https://developer.nvidia.com/cuda-downloads
WHISPER_DEVICE=cpu
# Compute type: int8 (CPU, default) | float16 (GPU/CUDA, auto-set when WHISPER_DEVICE=cuda/gpu)
WHISPER_COMPUTE_TYPE=int8
# Language code for transcription (e.g. en, es, fr, de, pt, ja, zh).
# Leave blank to auto-detect the language of each utterance (recommended for multilanguage use).
WHISPER_LANGUAGE=

# ── LLM — Local (Ollama) ──────────────────────────────────────────────────
OLLAMA_MODEL=llama3
OLLAMA_BASE_URL=http://localhost:11434

# ── LLM — AWS Bedrock ─────────────────────────────────────────────────────
# AWS named profile from ~/.aws/credentials or ~/.aws/config
# Leave blank to use the default credential chain (env vars, instance role, etc.)
AWS_PROFILE=default
AWS_REGION=us-east-1
# Default Bedrock model used when provider=bedrock and no model query param is given
BEDROCK_DEFAULT_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# ── TTS (pyttsx3) ─────────────────────────────────────────────────────────
TTS_RATE=180
TTS_VOLUME=1.0
